# =============================================================================
# Veily — .gitignore
# =============================================================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependencies
node_modules/
api/node_modules/

# Build outputs
dist/
dist-ssr/
dist_electron/
.vite/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Environment — NEVER commit secrets
.env
.env.*
*.local

# Rust / Tauri — can be multiple GB
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/

# Tauri signing keys — NEVER commit
*.pem
*.key
.tauri/

# Release bundles — binaries don't belong in git
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.msi
src-tauri/target/release/bundle/

# Vercel
.vercel/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db
desktop.ini

# Tool-specific
.agents/
.agent/
_agents/
_agent/
.cursor/
.history/

# Test / coverage
coverage/
*.lcov
test-results/
playwright-report/

# Misc
dev-app-update.yml
*.zip

# Lock files — keep only npm's (delete the others if present)
yarn.lock
pnpm-lock.yaml
